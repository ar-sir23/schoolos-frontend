{
  "redirects": [
    { "source": "/", "destination": "/landing/index.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/landing/(.*)", "destination": "/landing/$1" },
    { "source": "/app/(.*)", "destination": "/index.html" },
    { "source": "/app", "destination": "/index.html" },
    { "source": "/signup", "destination": "/index.html" }
  ]
}
